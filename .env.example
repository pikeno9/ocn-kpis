# ===================================================================
# Variáveis de ambiente — defina no Railway (Settings → Variables).
# NÃO comitar valores reais. Este arquivo é só um modelo.
# ===================================================================

# Usuários (logins fixos). Gere cada hash com:  npm run hash -- "sua-senha"
# Cole o JSON inteiro em UMA linha. role pode ser "admin" ou "viewer".
AUTH_USERS=[{"login":"enrico","name":"Enrico","role":"admin","hash":"$2a$10$COLE_O_HASH_AQUI"}]

# Segredo que assina o cookie de sessão (string aleatória forte). Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=troque-por-uma-string-aleatoria-forte

# Opcionais
# CRON_SCHEDULE=0 5 * * *          # atualização dos dados (default diária 05:00 BRT)
# REFERENCE_DATE=2026-06-24        # fixa a data dos cálculos (default: hoje)
